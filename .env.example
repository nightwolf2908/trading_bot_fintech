# ============================================
# .env.example - Variables de entorno
# ============================================
# COPIA ESTE ARCHIVO A .env Y COMPLETA TUS DATOS
# ============================================

# ----- BINANCE TESTNET API KEYS -----
# Obténlas en: https://testnet.binance.vision/
BINANCE_API_KEY=TU_API_KEY_AQUI
BINANCE_SECRET_KEY=TU_SECRET_KEY_AQUI

# ----- MODO DE OPERACIÓN -----
# True = Testnet (dinero de prueba - RECOMENDADO)
# False = Producción (dinero real - ¡CUIDADO!)
BINANCE_TESTNET=True

# ----- CONFIGURACIÓN -----
# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Par de trading (BTC/USDT, ETH/USDT, etc.)
TRADING_SYMBOL=BTC/USDT

# Riesgo por operación (0.025 = 2.5% del balance)
RISK_PERCENTAGE=0.025